{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "StreamNet TV",
  "version": "2.1.4",
  "identifier": "tv.streamnet.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "",
    "devUrl": "https://web.streamnet.live",
    "frontendDist": "../public"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "StreamNet TV",
        "url": "https://web.streamnet.live",
        "width": 1440,
        "height": 920,
        "minWidth": 980,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
