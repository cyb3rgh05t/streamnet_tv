# =====================================================
# StreamNet TV - Production Environment Configuration
# Copy this file to .env and fill in the values.
# =====================================================

# ── Server ────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── Security ──────────────────────────────────────
# Strong random string for JWT signing and session secret.
# Generate with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string

# ── Xtream Multi-User Login Mode ──────────────────
# Set XTREAM_AUTH_ENABLED=true to run as a central server where users log in
# with their own Xtream credentials (no local user management needed).
#
# How it works:
#   - Users authenticate directly against XTREAM_PORTAL_URL.
#   - A local app account is auto-provisioned per Xtream username.
#   - Each user gets their own isolated Source / Channels / Settings.
#   - Setup-screen and SSO button are hidden in this mode.
#
XTREAM_AUTH_ENABLED=true

# Optional: fixed reference capacities for dashboard utilization rings.
# Useful in production/container setups to avoid auto-scaling drift.
# NETWORK_CAPACITY_MBPS=1000
# DISK_RW_CAPACITY_MBPS=500

# ── OIDC / SSO (optional – leave empty to disable) ──
# OIDC_ISSUER=https://auth.example.com
# OIDC_CLIENT_ID=streamnet-tv
# OIDC_CLIENT_SECRET=secret
# OIDC_CALLBACK_URL=https://streamnet.example.com/api/auth/oidc/callback
